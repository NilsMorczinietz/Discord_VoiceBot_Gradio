{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Gradio App",
			"type": "shell",
			"command": ".venv\\Scripts\\python.exe",
			"args": [
				"src/gradio_app.py"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "Run Pytest (PYTHONPATH=src)",
			"type": "shell",
			"command": ".venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"pytest"
			],
			"options": {
				"env": {
					"PYTHONPATH": "src"
				}
			},
			"isBackground": false,
			"problemMatcher": []
		}
	]
}